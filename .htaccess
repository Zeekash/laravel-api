    RewriteRule ^citytocitydiffstate.routes.sitemap_14.xml$ public/citytocitydiffstate.routes.sitemap_14.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_15.xml$ public/citytocitydiffstate.routes.sitemap_15.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_16.xml$ public/citytocitydiffstate.routes.sitemap_16.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_17.xml$ public/citytocitydiffstate.routes.sitemap_17.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_18.xml$ public/citytocitydiffstate.routes.sitemap_18.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_19.xml$ public/citytocitydiffstate.routes.sitemap_19.xml [L]
    
    #State to City Route
    RewriteRule ^statetocity.routes.sitemap_index.xml$ public/statetocity.routes.sitemap_index.xml [L]
    RewriteRule ^statetocity.routes.sitemap_1.xml$ public/statetocity.routes.sitemap_1.xml [L]
    RewriteRule ^statetocity.routes.sitemap_2.xml$ public/statetocity.routes.sitemap_2.xml [L]
    RewriteRule ^statetocity.routes.sitemap_3.xml$ public/statetocity.routes.sitemap_3.xml [L]
    RewriteRule ^statetocity.routes.sitemap_4.xml$ public/statetocity.routes.sitemap_4.xml [L]
    RewriteRule ^statetocity.routes.sitemap_5.xml$ public/statetocity.routes.sitemap_5.xml [L]
    RewriteRule ^statetocity.routes.sitemap_6.xml$ public/statetocity.routes.sitemap_6.xml [L]
    RewriteRule ^statetocity.routes.sitemap_7.xml$ public/statetocity.routes.sitemap_7.xml [L]
    RewriteRule ^statetocity.routes.sitemap_8.xml$ public/statetocity.routes.sitemap_8.xml [L]
    
    #City to State Route
    RewriteRule ^citytostate.routes.sitemap_index.xml$ public/citytostate.routes.sitemap_index.xml [L]
    RewriteRule ^citytostate.routes.sitemap_1.xml$ public/citytostate.routes.sitemap_1.xml [L]
