<IfModule mod_rewrite.c>
     RewriteEngine On
    RewriteBase /
    
    # Block external AMP access
    # RewriteCond %{HTTP_HOST} !^mymovingjourney\.com$ [NC]
    # RewriteRule ^ - [F]
    
    # Header set Content-Security-Policy "frame-ancestors 'self';"
    # Header always set X-Frame-Options "SAMEORIGIN"
    # Header set X-Content-Type-Options "nosniff"
    # Header set Referrer-Policy "strict-origin-when-cross-origin"

    # ✅ Redirect uppercase URLs to lowercase using PHP script
    RewriteCond %{REQUEST_URI} [A-Z]
    RewriteCond %{REQUEST_URI} !^/(assets|backend)/ [NC]
    # RewriteRule ^(.*)$ public/redirect_to_lowercase.php 
    
    RewriteCond %{THE_REQUEST} \s/index\.php[/?\s] [NC]
RewriteRule ^index\.php/?(.*)$ /$1 [R=301,L]

RewriteCond %{QUERY_STRING} (\think\\|call_user_func_array|invokefunction) [NC]
RewriteRule .* - [F,L]


    # 1) If the raw request has multiple leading slashes, 301 to the same path once normalized
    RewriteCond %{THE_REQUEST} \s/{2,}([^\s?]*) [NC]
    RewriteRule ^ https://%{HTTP_HOST}%1 [R=301,L]
    
    # 2) Collapse any double slashes that appear anywhere in the path (mid-path), once
    RewriteCond %{REQUEST_URI} ^(.*/)//+(.*)$
    RewriteRule ^ %1/%2 [R=301,L]

    # ✅ Remove trailing slash from non-directory URLs
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]

    # Redirect 'www' to non-'www'
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
    
    
    # Redirects
    Redirect 301 /move-cost/alaska /movers-list/alaska
    RewriteRule ^move-cost/alaska$ /movers-list/alaska [L]
    
    Redirect 301 /movers/alaska /movers-list/alaska
    RewriteRule ^movers/alaska$ /movers-list/alaska [L]
    
    Redirect 301 /mover/swift-shift-van-lines /mover/swift-shift-vanlines
    RewriteRule ^mover/swift-shift-van-lines /mover/swift-shift-vanlines [L]
    
    Redirect 301 /move-cost/district-of-columbia /movers-list/district-of-columbia
    RewriteRule ^move-cost/district-of-columbia /movers-list/district-of-columbia [L]
    
    Redirect 301 /movers/district-of-columbia /movers-list/district-of-columbia
    RewriteRule ^movers/district-of-columbia /movers-list/district-of-columbia [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-florida /movers/florida
    RewriteRule ^resource/top-rated-moving-companies-in-florida /movers/florida [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-california /movers/california
    RewriteRule ^resource/top-rated-moving-companies-in-california /movers/california [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-illinois /movers/illinois
    RewriteRule ^resource/top-rated-moving-companies-in-illinois /movers/illinois [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-new-york /movers/new-york
    RewriteRule ^resource/top-rated-moving-companies-in-new-york /movers/new-york [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-texas /movers/texas
    RewriteRule ^resource/top-rated-moving-companies-in-texas /movers/texas [L]
    
    Redirect 301 /resource/top-rated-moving-companies-in-new-jersey /movers/new-jersey
    RewriteRule ^resource/top-rated-moving-companies-in-new-jersey /movers/new-jersey [L]
    
    Redirect 301 /move-cost/hawaii /movers-list/hawaii
    RewriteRule ^move-cost/hawaii /movers-list/hawaii [L]
    
    Redirect 301 /movers/hawaii /movers-list/hawaii
    RewriteRule ^movers/hawaii /movers-list/hawaii [L]
    
    Redirect 301 /movers/lowa /movers/iowa
    RewriteRule ^movers/lowa /movers/iowa [L]
    
    Redirect 301 /move-cost/utha /move-cost/utah
    RewriteRule ^move-cost/utha /move-cost/utah [L]
    
    Redirect 301 /move-cost/lowa /move-cost/iowa
    RewriteRule ^move-cost/lowa /move-cost/iowa [L]
    
    Redirect 301 /blogs/managing-depression-after-relocating /blogs/how-to-cope-with-relocation-depression
    RewriteRule ^blogs/managing-depression-after-relocating /blogs/how-to-cope-with-relocation-depression [L]
    
    Redirect 301 /blogs/packing-checklist-for-moving-abroad-2025 /blogs/packing-checklist-for-moving-abroad
    Redirect 301 /blogs/best-packing-tips-for-long-distance-moving-2025 /blogs/best-packing-tips-for-long-distance-moving
    Redirect 301 /blogs/best-places-to-retire-in-the-usa-in-2025 /blogs/best-places-to-retire-in-the-usa
    Redirect 301 /blogs/where-are-people-moving-to-in-2025 /blogs/where-are-people-moving-to
    Redirect 301 /blogs/moving-to-costa-rica-a-relocation-guide-2025 /blogs/moving-to-costa-rica-a-relocation-guide
    Redirect 301 /blogs/things-to-know-before-moving-to-california-in-2025 /blogs/things-to-know-before-moving-to-california
    Redirect 301 /blogs/where-to-find-free-moving-boxes-in-2025 /blogs/where-to-find-free-moving-boxes
    Redirect 301 /blogs/best-cities-for-young-professionals-in-the-usa-in-2025 /blogs/best-cities-for-young-professionals-in-the-usa
    Redirect 301 /blogs/top-states-to-move-to-in-2025 /blogs/top-states-to-move-to
    Redirect 301 /blogs/how-climate-and-weather-are-influencing-where-people-move-in-2025 /blogs/how-climate-and-weather-are-influencing-where-people-move
    
    Redirect 301 /mover/noble-moving-and-storage /movers-list

    
    Redirect 301 /moving-routes/ms/ms /moving-routes/ms
    RewriteRule ^moving-routes/ms/ms /moving-routes/ms [L]
    
    Redirect 301 /moving-routes/resource/best-state-to-state-moving-companies /resource/best-long-distance-moving-companies
    RewriteRule ^moving-routes/resource/best-state-to-state-moving-companies /resource/best-long-distance-moving-companies [L]
    
    Redirect 301 /moving-routes/resource/best-moving-companies /resource/best-long-distance-moving-companies
    RewriteRule ^moving-routes/resource/best-moving-companies /resource/best-long-distance-moving-companies [L]
    
    
    
    
     # Block access to sensitive directories
    RewriteRule ^.env(/|$) - [R=404,L]
    RewriteRule ^routes(/|$) - [R=404,L]
    RewriteRule ^app(/|$) - [R=404,L]
    RewriteRule ^config(/|$) - [R=404,L]
    RewriteRule ^database(/|$) - [R=404,L]
    RewriteRule ^resources(/|$) - [R=404,L]
    RewriteRule ^storage(/|$) - [R=404,L]
    RewriteRule ^tests(/|$) - [R=404,L]
    RewriteRule ^node_modules(/|$) - [R=404,L]
    RewriteRule ^vendor(/|$) - [R=404,L]
    
    # Route requests for sitemap.xml to public/.html&.xml&.php&.shtml
    RewriteRule ^sitemap.xml$ public/sitemap.xml [L]
    
    RewriteRule ^blog.sitemap.html$ public/blog.sitemap.html [L]
    RewriteRule ^blog.sitemap.xml$ public/blog.sitemap.xml [L]
    
    RewriteRule ^mover-states.sitemap.xml$ public/mover-states.sitemap.xml [L]
    RewriteRule ^mover-states.sitemap.html$ public/mover-states.sitemap.html [L]
    
    RewriteRule ^state-move-cost.sitemap.xml$ public/state-move-cost.sitemap.xml [L]
    RewriteRule ^state-move-cost.sitemap.html$ public/state-move-cost.sitemap.html [L]
    
    RewriteRule ^city.sitemap.html public/city.sitemap.html [L]
    RewriteRule ^city.sitemap.xml public/city.sitemap.xml [L]
    
    RewriteRule ^company.sitemap.html$ public/company.sitemap.html [L]
    RewriteRule ^company.sitemap.xml$ public/company.sitemap.xml [L]
    
    RewriteRule ^redirect_to_lowercase.php$ public/redirect_to_lowercase.php [L]
    
    RewriteRule ^resources.sitemap.html$ public/resources.sitemap.html [L]
    RewriteRule ^resources.sitemap.xml$ public/resources.sitemap.xml [L]
    
    RewriteRule ^redirect_to_lowercase.php$ public/redirect_to_lowercase.php [L]
    
    RewriteRule ^robots.txt$ public/robots.txt [L]
    
    # RewriteRule ^403.shtml$ public/403.shtml [L]
    # RewriteRule ^404.shtml$ public/404.shtml [L]
    
    # RewriteRule ^routes.sitemap.html$ public/routes.sitemap.html [L]
    # RewriteRule ^routes.sitemap.xml$ public/routes.sitemap.xml [L]
    
    RewriteRule ^sitemap-main.xml$ public/sitemap-main.xml [L]
    
    RewriteRule ^state.sitemap.html$ public/state.sitemap.html [L]
    RewriteRule ^state.sitemap.xml$ public/state.sitemap.xml [L]
    
    RewriteRule ^blog-live-urls.html$ public/blog-live-urls.html [L]
    
    RewriteRule ^state-route.sitemap.html$ public/state-route.sitemap.html [L]
    RewriteRule ^state-route.sitemap.xml$ public/state-route.sitemap.xml [L]
    
    #State to State Route
    RewriteRule ^statetostate.routes.sitemap.html$ public/statetostate.routes.sitemap.html [L]
    RewriteRule ^statetostate.routes.sitemap.xml$ public/statetostate.routes.sitemap.xml [L]
    
    #City to City (Another State) Route
    RewriteRule ^citytocitydiffstate.routes.sitemap_index.xml$ public/citytocitydiffstate.routes.sitemap_index.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_1.xml$ public/citytocitydiffstate.routes.sitemap_1.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_2.xml$ public/citytocitydiffstate.routes.sitemap_2.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_3.xml$ public/citytocitydiffstate.routes.sitemap_3.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_4.xml$ public/citytocitydiffstate.routes.sitemap_4.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_5.xml$ public/citytocitydiffstate.routes.sitemap_5.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_6.xml$ public/citytocitydiffstate.routes.sitemap_6.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_7.xml$ public/citytocitydiffstate.routes.sitemap_7.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_8.xml$ public/citytocitydiffstate.routes.sitemap_8.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_9.xml$ public/citytocitydiffstate.routes.sitemap_9.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_10.xml$ public/citytocitydiffstate.routes.sitemap_10.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_11.xml$ public/citytocitydiffstate.routes.sitemap_11.xml [L]
    RewriteRule ^citytocitydiffstate.routes.sitemap_12.xml$ public/citytocitydiffstate.routes.sitemap_12.xml [L]
